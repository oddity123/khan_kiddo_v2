# Khan Kiddo v2 环境变量模板
# 用法：cp .env.example .env 后填入真实值；.env 已在 .gitignore 中，切勿提交
#
# Spring Boot 不会自动读取 .env，启动前需手动 export，例如：
#   set -a && source .env && set +a
#   cd backend && ./mvn.sh spring-boot:run
# IDEA：Run Configuration → Environment variables → 从 .env 导入

# ===========================================
# JWT 认证（敏感，生产必填）
# ===========================================
# 至少 32 字符；前端通过 Authorization: Bearer <token> 访问受保护 API

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION_HOURS=168

# ===========================================
# 服务
# ===========================================

# 后端端口（application.yml: server.port，默认 8080）
PORT=8080

# 网站备案信息（页脚展示，可选覆盖）
# APP_ICP_NUMBER=鄂ICP备2026025924号
# APP_ICP_URL=https://beian.miit.gov.cn/
# APP_PSB_NUMBER=鄂公网安备42010202002911号
# APP_PSB_URL=https://beian.mps.gov.cn/#/query/webSearch?code=42010202002911

# Spring Profile（dev / test / prod）
# 生产服务器务必设为 prod，以启用 application-prod.yml 并禁用开发默认值
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# 数据库（敏感）
# ===========================================

DB_URL=jdbc:mysql://localhost:3306/khan_kiddo_dev?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your-db-password-here

# ===========================================
# 豆包 / 火山方舟（app.llm doubao-seed、LangChain4j 默认 Bean）
# ===========================================
# 控制台：https://console.volcengine.com/ark

DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_MODEL_NAME=doubao-seed-1-8-251228

# ===========================================
# 通义千问（app.llm qwen-plus）
# ===========================================
# 控制台：https://dashscope.console.aliyun.com/

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_MODEL_NAME=qwen-plus

# ===========================================
# 兼容旧变量名（可选；未设置 DOUBAO_* 时 LangChain4j 可回退）
# ===========================================

# AI_API_KEY=
# AI_BASE_URL=
# AI_MODEL=

# Stage 1 对话分离（Flash，更快更省）
AI_SEPARATION_MODEL=doubao-seed-1-6-flash-250828
AI_SEPARATION_TEMPERATURE=0.3

# 采样与请求限制（app.llm / LangChain4j 共用）
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=10240
AI_TIMEOUT_MS=120s
AI_MAX_RETRIES=3

# ===========================================
# 日志（Spring Boot 3 兼容写法）
# ===========================================
# 勿使用 LOGGING_LEVEL=INFO — 会与 Spring Boot 3 绑定冲突导致启动失败
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_KHANKIDDO_LEARNING=DEBUG
