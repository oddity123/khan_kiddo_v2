# Khan Kiddo v2 环境变量模板
# 用法：cp .env.example .env 后填入真实值；.env 已在 .gitignore 中，切勿提交
#
# Spring Boot 不会自动读取 .env，启动前需手动 export，例如：
#   set -a && source .env && set +a
#   cd backend && ./mvn.sh spring-boot:run
# IDEA：Run Configuration → Environment variables → 从 .env 导入

# ===========================================
# JWT 认证（敏感，生产必填）
# ===========================================
# 至少 32 字符；前端通过 Authorization: Bearer <token> 访问受保护 API

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRATION_HOURS=168

# ===========================================
# 服务
# ===========================================

# 后端端口（application.yml: server.port，默认 8081）
PORT=8081

# Spring Profile（dev / test / prod）
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# 数据库（敏感）
# ===========================================

DB_URL=jdbc:mysql://localhost:3306/khan_kiddo_dev?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your-db-password-here

# ===========================================
# 豆包 / 火山方舟 LLM（敏感，必填才能调用 AI）
# ===========================================
# 控制台：https://console.volcengine.com/ark

AI_API_KEY=your-doubao-api-key-here
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_MODEL=doubao-seed-1-8-251228

# Stage 1 对话分离（Flash，更快更省；对齐 v1）
AI_SEPARATION_MODEL=doubao-seed-1-6-flash-250828
AI_SEPARATION_TEMPERATURE=0.3

# 主分析 / 总结（v1 默认 0.4）
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=2048
AI_TIMEOUT_MS=120s
AI_MAX_RETRIES=3

# ===========================================
# 有道词典 API（敏感，单词查询功能迁移后使用）
# ===========================================
# 控制台：https://ai.youdao.com

# YOUDAO_APP_KEY=your-youdao-app-key-here
# YOUDAO_APP_SECRET=your-youdao-app-secret-here

# ===========================================
# 日志（Spring Boot 3 兼容写法）
# ===========================================
# 勿使用 LOGGING_LEVEL=INFO — 会与 Spring Boot 3 绑定冲突导致启动失败
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_KHANKIDDO_LEARNING=DEBUG
