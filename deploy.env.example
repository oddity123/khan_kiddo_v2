# 阿里云 ECS / 宝塔 一键上传配置（复制为 deploy.env 后填写）
#   cp deploy.env.example deploy.env
# deploy.env 已 gitignore，切勿提交
#
# 本配置只用于 ./deploy.sh 上传文件；后端请在宝塔面板手动重启。

# SSH
DEPLOY_HOST=47.x.x.x
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_SSH_KEY=

# 前端：Nginx 站点根目录（会解压 dist.zip 到此）
DEPLOY_FRONTEND_DIR=/www/wwwroot/你的站点目录

# 后端：jar 上传目录
DEPLOY_BACKEND_DIR=/www/wwwroot

# 远端 jar 完整路径（建议与宝塔启动命令里 -jar 路径一致，上传时直接覆盖）
DEPLOY_BACKEND_JAR=/www/wwwroot/khankiddo-v2-3.0.0-SNAPSHOT.jar

# 上传前是否本地 ./package.sh（1=是，0=否）
DEPLOY_BUILD_FIRST=1
